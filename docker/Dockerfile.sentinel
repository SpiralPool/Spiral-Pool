# ╔════════════════════════════════════════════════════════════════════════════╗
# ║                      SPIRAL SENTINEL - DOCKER IMAGE                        ║
# ╚════════════════════════════════════════════════════════════════════════════╝

FROM python:3.12-slim

LABEL maintainer="Spiral Miner"
LABEL description="Spiral Sentinel - Mining Monitor"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Create user
RUN useradd -r -m -s /bin/bash spiraluser

# Install dependencies from pinned requirements.txt (reproducible builds)
COPY src/sentinel/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && rm /tmp/requirements.txt

# Create directories (config in home, shared data in /spiralpool)
RUN mkdir -p /home/spiraluser/.spiralsentinel \
    && mkdir -p /spiralpool/data \
    && chown -R spiraluser:spiraluser /home/spiraluser \
    && chown -R spiraluser:spiraluser /spiralpool

# Copy sentinel
COPY --chown=spiraluser:spiraluser src/sentinel/SpiralSentinel.py /app/SpiralSentinel.py
COPY --chown=spiraluser:spiraluser src/sentinel/ha_manager.py /app/ha_manager.py

WORKDIR /app

USER spiraluser

CMD ["python", "SpiralSentinel.py"]
