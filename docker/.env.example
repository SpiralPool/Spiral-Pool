# ╔════════════════════════════════════════════════════════════════════════════╗
# ║                    SPIRAL POOL - DOCKER CONFIGURATION                      ║
# ║                    Solo Mining (V1 Stratum)                               ║
# ╚════════════════════════════════════════════════════════════════════════════╝
#
# QUICK START (single-coin):
#   1. cp .env.example .env
#   2. Edit .env — set POOL_COIN and POOL_ADDRESS
#   3. ./generate-secrets.sh          (auto-generates all passwords)
#   4. docker compose --profile <coin> up -d
#
# QUICK START (multi-coin):
#   1. cp .env.example .env
#   2. Set POOL_MODE=multi
#   3. Set ENABLE_<COIN>=true and <COIN>_POOL_ADDRESS for each coin
#   4. ./generate-secrets.sh
#   5. docker compose --profile multi up -d
#
# Available profiles:
#   Single-coin: dgb, btc, bch, bc2, nmc, sys, xmy, fbtc, qbx, ltc, doge, dgb-scrypt, pep, cat
#   Multi-coin:  multi (launches all ENABLE_<COIN>=true coins)
#
# For V2 Enhanced Stratum (SV2 binary protocol): sudo ./install.sh

# ═══════════════════════════════════════════════════════════════════════════════
# POOL MODE (single or multi)
# ═══════════════════════════════════════════════════════════════════════════════
# single = one coin per deployment (default, uses POOL_COIN below)
# multi  = multiple coins in one deployment (uses ENABLE_* flags below)
POOL_MODE=single

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 1a: SINGLE-COIN MODE (POOL_MODE=single)
# ═══════════════════════════════════════════════════════════════════════════════

# Pool coin type — must match the --profile you use
# Valid: bitcoin, litecoin, digibyte, dgb-scrypt (or digibyte-scrypt),
#        bitcoincash, bitcoinii, dogecoin, pepecoin, catcoin, namecoin,
#        syscoin, myriadcoin, fractalbitcoin, qbitx
#
# DGB-SCRYPT: Use POOL_COIN=dgb-scrypt with --profile dgb-scrypt.
#   Ports (3336/3338) and POOL_ID (dgb_scrypt_1) are auto-detected.
POOL_COIN=digibyte

# Pool ID — format: <symbol>_<algo>_<n>
# Examples: dgb_sha256_1, btc_sha256_1, ltc_scrypt_1
POOL_ID=dgb_sha256_1

# Your wallet address for the chosen coin (required)
POOL_ADDRESS=YOUR_WALLET_ADDRESS_HERE

# Coinbase text (appears in mined blocks, max 40 bytes)
COINBASE_TEXT=Mined by Spiral Pool

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 2: PASSWORDS (required — run ./generate-secrets.sh to auto-fill)
# ═══════════════════════════════════════════════════════════════════════════════
# NOTE: Daemon host, ports, and RPC credentials are auto-detected from
# POOL_COIN and the coin-specific RPC password below. No manual configuration
# needed — just set POOL_COIN (Step 1) and run generate-secrets.sh.

# Database password
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Grafana admin password
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Admin API key (for admin endpoints)
ADMIN_API_KEY=CHANGE_THIS_TO_A_STRONG_KEY

# RPC passwords for coin daemons.
# Only the password for your chosen coin matters — the stratum auto-detects it.
# generate-secrets.sh fills ALL of them, which is fine.

# SHA-256d Coins
DGB_RPC_USER=spiraldgb
DGB_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
BTC_RPC_USER=spiralbtc
BTC_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
BCH_RPC_USER=spiralbch
BCH_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
BC2_RPC_USER=spiralbc2
BC2_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
NMC_RPC_USER=spiralnmc
NMC_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
SYS_RPC_USER=spiralsys
SYS_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
XMY_RPC_USER=spiralxmy
XMY_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
FBTC_RPC_USER=spiralfbtc
FBTC_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
QBX_RPC_USER=spiralqbx
QBX_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Scrypt Coins
LTC_RPC_USER=spiralltc
LTC_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DOGE_RPC_USER=spiraldoge
DOGE_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
PEP_RPC_USER=spiralpep
PEP_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
CAT_RPC_USER=spiralcat
CAT_RPC_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# ═══════════════════════════════════════════════════════════════════════════════
# STEP 1b: MULTI-COIN MODE (POOL_MODE=multi)
# ═══════════════════════════════════════════════════════════════════════════════
# Enable coins by setting ENABLE_<COIN>=true and providing wallet addresses.
# Only enabled coins will be configured. Use --profile multi to start.

# --- SHA-256d Coins ---
ENABLE_DGB=false
DGB_POOL_ADDRESS=
ENABLE_BTC=false
BTC_POOL_ADDRESS=
ENABLE_BCH=false
BCH_POOL_ADDRESS=
ENABLE_BC2=false
BC2_POOL_ADDRESS=
ENABLE_NMC=false
NMC_POOL_ADDRESS=
ENABLE_SYS=false
SYS_POOL_ADDRESS=
ENABLE_XMY=false
XMY_POOL_ADDRESS=
ENABLE_FBTC=false
FBTC_POOL_ADDRESS=
ENABLE_QBX=false
QBX_POOL_ADDRESS=

# --- Scrypt Coins ---
ENABLE_LTC=false
LTC_POOL_ADDRESS=
ENABLE_DOGE=false
DOGE_POOL_ADDRESS=
ENABLE_DGB_SCRYPT=false
# DGB_POOL_ADDRESS is shared with DGB above
ENABLE_PEP=false
PEP_POOL_ADDRESS=
ENABLE_CAT=false
CAT_POOL_ADDRESS=

# --- Merge Mining (multi-coin mode only) ---
# Merge mining lets you mine aux chains alongside a parent chain for free.
# SHA-256d parent: BTC (or DGB if BTC disabled). Aux: NMC, SYS, XMY, FBTC
# Scrypt parent: LTC. Aux: DOGE, PEP
MERGE_MINING_ENABLED=false
# Which algo to merge-mine: sha256d, scrypt, or both
MERGE_MINING_ALGO=sha256d
# Comma-separated aux chains for SHA-256d parent (e.g., NMC,SYS,FBTC)
MERGE_MINING_AUX_CHAINS_SHA256D=
# Comma-separated aux chains for Scrypt parent (e.g., DOGE,PEP)
MERGE_MINING_AUX_CHAINS_SCRYPT=

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL SETTINGS (defaults work for most setups)
# ═══════════════════════════════════════════════════════════════════════════════

# Database (defaults are fine)
DB_USER=spiralstratum
DB_NAME=spiralstratum
DB_PORT=5432

# Expected fleet hashrate in TH/s (for monitoring alerts)
EXPECTED_FLEET_THS=22

# Dashboard authentication
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_SESSION_LIFETIME=24
DASHBOARD_API_KEY=
DASHBOARD_CORS_ORIGINS=

# Prometheus metrics token (optional — set to require Bearer auth on /metrics)
SPIRAL_METRICS_TOKEN=

# --- STRATUM DIFFICULTY ---
# Defaults work for most setups. Override for ASIC farms or specific hardware.
# STRATUM_DIFF_INITIAL: Starting difficulty for unrecognized miners (vardiff adjusts from here)
# STRATUM_DIFF_MIN:     Lowest difficulty vardiff can drop to (0.001 supports ESP32 lottery miners)
# STRATUM_DIFF_MAX:     Highest difficulty vardiff can reach (1T supports S21 on BTC)
# STRATUM_VARDIFF_TARGET_TIME: Target seconds between shares
STRATUM_DIFF_INITIAL=5000
STRATUM_DIFF_MIN=0.001
STRATUM_DIFF_MAX=1000000000000
STRATUM_VARDIFF_TARGET_TIME=4

# --- ASICBOOST / VERSION ROLLING ---
# Required for S19/S21/Vnish firmware. Enabled by default.
# Set to false only if you need to disable AsicBoost for debugging.
STRATUM_VERSION_ROLLING=true
STRATUM_VERSION_ROLLING_MASK=536862720

# --- STRATUM V2 (Noise Protocol Encryption) ---
# Enable V2 Enhanced Stratum alongside V1. V2 uses the SV2 binary protocol
# with Noise_NX_secp256k1_ChaChaPoly_SHA256 encryption — keys are generated
# in memory at startup. No certificate files or manual key management needed.
# Each coin gets a dedicated V2 port (typically V1 port + 1).
# Miners connect via: stratum+sv2://YOUR_IP:V2_PORT
STRATUM_V2_ENABLED=false

# ═══════════════════════════════════════════════════════════════════════════════
# NOTIFICATIONS (optional — leave empty to disable)
# ═══════════════════════════════════════════════════════════════════════════════

# Discord
DISCORD_WEBHOOK_URL=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# XMPP/Jabber
XMPP_JID=
XMPP_PASSWORD=
XMPP_RECIPIENT=

# ntfy push notifications (free mobile/desktop push — no account needed for public topics)
# NTFY_URL=https://ntfy.sh/your-topic
# NTFY_TOKEN=

# Generic webhook (POST JSON to any URL)
# WEBHOOK_URL=https://your-server.com/alerts
# WEBHOOK_HEADERS={"Authorization": "Bearer your-token"}

# SMTP / Email notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=you@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@gmail.com
# SMTP_TO=you@gmail.com

# Alert theme (cyberpunk or professional)
ALERT_THEME=cyberpunk

# ═══════════════════════════════════════════════════════════════════════════════
# ADVANCED (override only if needed)
# ═══════════════════════════════════════════════════════════════════════════════

# Daemon connection overrides (auto-detected from POOL_COIN — rarely needed)
# Only set these if connecting to a remote daemon or non-standard ports.
# ┌──────────────────┬───────────────┬──────────┬──────────────┬──────────────┬──────────────┐
# │ Coin             │ DAEMON_HOST   │ RPC_PORT │ ZMQ_PORT     │ STRATUM_PORT │ STRATUM_TLS  │
# ├──────────────────┼───────────────┼──────────┼──────────────┼──────────────┼──────────────┤
# │ digibyte         │ digibyte      │ 14022    │ 28532        │ 3333         │ 3335         │
# │ dgb-scrypt       │ digibyte      │ 14022    │ 28532        │ 3336         │ 3338         │
# │ bitcoin          │ bitcoin       │ 8332     │ 28332        │ 4333         │ 4335         │
# │ bitcoincash      │ bitcoincash   │ 8432     │ 28432        │ 5333         │ 5335         │
# │ bitcoinii        │ bitcoinii     │ 8339     │ 28338        │ 6333         │ 6335         │
# │ namecoin         │ namecoin      │ 8336     │ 28336        │ 14335        │ 14337        │
# │ syscoin          │ syscoin       │ 8370     │ 28370        │ 15335        │ 15337        │
# │ myriadcoin       │ myriadcoin    │ 10889    │ 28889        │ 17335        │ 17337        │
# │ fractalbitcoin   │ fractalbitcoin│ 8340     │ 28340        │ 18335        │ 18337        │
# │ qbitx            │ qbitx        │ 8344     │ 28344        │ 20335        │ 20337        │
# │ litecoin         │ litecoin      │ 9332     │ 28933        │ 7333         │ 7335         │
# │ dogecoin         │ dogecoin      │ 22555    │ 28555        │ 8335         │ 8342         │
# │ pepecoin         │ pepecoin      │ 33873    │ 28873        │ 10335        │ 10337        │
# │ catcoin          │ catcoin       │ 9932     │ 28932        │ 12335        │ 12337        │
# └──────────────────┴───────────────┴──────────┴──────────────┴──────────────┴──────────────┘
# DAEMON_HOST=
# DAEMON_RPC_PORT=
# DAEMON_RPC_USER=
# DAEMON_RPC_PASSWORD=
# DAEMON_ZMQ_PORT=
# STRATUM_PORT=
# STRATUM_PORT_TLS=

# ═══════════════════════════════════════════════════════════════════════════════
# HIGH AVAILABILITY (docker-compose.ha.yml)
# ═══════════════════════════════════════════════════════════════════════════════
# Required only when using: docker compose -f docker-compose.yml -f docker-compose.ha.yml up
# These are used by Patroni for PostgreSQL replication and failover.
# REPLICATION_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
# REWIND_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
# PATRONI_REST_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD

# Override default Docker volume with host path for blockchain data
# Example: DGB_DATA_DIR=/mnt/ssd/digibyte
# DGB_DATA_DIR=
# BTC_DATA_DIR=
# BCH_DATA_DIR=
# BC2_DATA_DIR=
# NMC_DATA_DIR=
# SYS_DATA_DIR=
# XMY_DATA_DIR=
# FBTC_DATA_DIR=
# QBX_DATA_DIR=
# LTC_DATA_DIR=
# DOGE_DATA_DIR=
# PEP_DATA_DIR=
# CAT_DATA_DIR=
