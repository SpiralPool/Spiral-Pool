# ╔════════════════════════════════════════════════════════════════════════════╗
# ║                                                                            ║
# ║                    BITCOIN II CORE - DOCKER IMAGE                          ║
# ║                                                                            ║
# ║   Separate container for Bitcoin II Core node (SHA-256d mining)            ║
# ║   This allows independent scaling and management                           ║
# ║                                                                            ║
# ║   CRITICAL: Bitcoin II uses identical address formats to Bitcoin.          ║
# ║   Ensure your wallet address was generated by Bitcoin II Core,             ║
# ║   not Bitcoin Core!                                                        ║
# ║                                                                            ║
# ╚════════════════════════════════════════════════════════════════════════════╝

FROM ubuntu:24.04

LABEL maintainer="Spiral Miner"
LABEL description="Bitcoin II Core Node for Spiral Pool"
LABEL version="29.1.0"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

ARG BITCOINII_VERSION=29.1.0

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    ca-certificates \
    libzmq3-dev \
    gosu \
    gettext-base \
    && rm -rf /var/lib/apt/lists/*

# Create bitcoinii user
RUN useradd -r -m -s /bin/bash bitcoinii \
    && mkdir -p /home/bitcoinii/.bitcoinii \
    && chown -R bitcoinii:bitcoinii /home/bitcoinii

# Download and install Bitcoin II Core
# Download Bitcoin II Core from official GitHub releases
# WARNING: ARM64 (aarch64) support is EXPERIMENTAL and UNTESTED.
# Upstream binaries exist but have not been verified in this Docker environment.
# IMPORTANT: Bitcoin II binaries use capital "II": bitcoinIId, bitcoinII-cli
# Note: v29.1.0 uses BitcoinII-29.1.0-x86_64-linux-CLI naming (capitalized BitcoinII)
# The extracted directory may be BitcoinII-VERSION-ARCH-linux-CLI or BitcoinII-VERSION
WORKDIR /tmp
RUN ARCH=$(dpkg --print-architecture) \
    && if [ "$ARCH" = "amd64" ]; then BC2_ARCH="x86_64-linux-CLI"; \
       elif [ "$ARCH" = "arm64" ]; then BC2_ARCH="aarch64-linux-CLI"; \
       else echo "Unsupported architecture: $ARCH" && exit 1; fi \
    && wget -q --max-redirect=5 "https://github.com/Bitcoin-II/BitcoinII-Core/releases/download/v${BITCOINII_VERSION}/BitcoinII-${BITCOINII_VERSION}-${BC2_ARCH}.tar.gz" \
    && tar -xzf "BitcoinII-${BITCOINII_VERSION}-${BC2_ARCH}.tar.gz" \
    && EXTRACTED_DIR=$(ls -d BitcoinII-*/ 2>/dev/null | head -1 | tr -d '/') \
    && if [ -d "$EXTRACTED_DIR/bin" ]; then cp "$EXTRACTED_DIR/bin/"* /usr/local/bin/; \
       else cp "$EXTRACTED_DIR/bitcoinIId" "$EXTRACTED_DIR/bitcoinII-cli" /usr/local/bin/ 2>/dev/null || true; fi \
    && chmod +x /usr/local/bin/bitcoinIId /usr/local/bin/bitcoinII-cli 2>/dev/null || true \
    && ln -sf /usr/local/bin/bitcoinIId /usr/local/bin/bitcoiniid \
    && ln -sf /usr/local/bin/bitcoinII-cli /usr/local/bin/bitcoinii-cli \
    && rm -rf /tmp/*

# Create entrypoint script
# IMPORTANT: Bitcoin II daemon binary is "bitcoinIId" (capital II)
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Process config template (replace env vars) — skip if user-provided config exists\n\
if [ -f /home/bitcoinii/.bitcoinii/bitcoinii.conf ] && [ -s /home/bitcoinii/.bitcoinii/bitcoinii.conf ]; then\n\
    echo "Using existing bitcoinii.conf (skipping template generation)"\n\
elif [ -f /config/bitcoinii.conf.template ]; then\n\
    envsubst < /config/bitcoinii.conf.template > /home/bitcoinii/.bitcoinii/bitcoinii.conf\n\
    chmod 600 /home/bitcoinii/.bitcoinii/bitcoinii.conf\n\
fi\n\
\n\
# Ensure proper ownership of data directory\n\
chown -R bitcoinii:bitcoinii /home/bitcoinii/.bitcoinii\n\
\n\
# Start Bitcoin II daemon (binary uses capital II: bitcoinIId)\n\
exec gosu bitcoinii bitcoinIId -printtoconsole "$@"\n\
' > /entrypoint.sh && chmod +x /entrypoint.sh

# Expose ports
# P2P
EXPOSE 8338
# RPC
EXPOSE 8339
# ZMQ
EXPOSE 28338

# Data volume
VOLUME ["/home/bitcoinii/.bitcoinii"]

USER root
ENTRYPOINT ["/entrypoint.sh"]
