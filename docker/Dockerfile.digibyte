# ╔════════════════════════════════════════════════════════════════════════════╗
# ║                                                                            ║
# ║                    DIGIBYTE NODE - DOCKER IMAGE                            ║
# ║                                                                            ║
# ║   Separate container for DigiByte Core node                                ║
# ║   This allows independent scaling and management                           ║
# ║                                                                            ║
# ╚════════════════════════════════════════════════════════════════════════════╝

FROM ubuntu:26.04

LABEL maintainer="Spiral Miner"
LABEL description="DigiByte Core Node for Spiral Pool"
LABEL version="8.26.2"

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=UTC

ARG DIGIBYTE_VERSION=8.26.2

# Install dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    wget \
    ca-certificates \
    libzmq3-dev \
    gosu \
    gettext-base \
    && rm -rf /var/lib/apt/lists/*

# Create digibyte user
RUN useradd -r -m -s /bin/bash digibyte \
    && mkdir -p /home/digibyte/.digibyte \
    && chown -R digibyte:digibyte /home/digibyte

# Download and install DigiByte Core
# NOTE: Only x86_64 (amd64) is supported.
WORKDIR /tmp
RUN if [ "$(dpkg --print-architecture)" != "amd64" ]; then \
        echo "ERROR: Only x86_64 (amd64) is supported." && exit 1; \
    fi \
    && wget -q --max-redirect=5 "https://github.com/DigiByte-Core/digibyte/releases/download/v${DIGIBYTE_VERSION}/digibyte-${DIGIBYTE_VERSION}-x86_64-linux-gnu.tar.gz" \
    && tar -tzf "digibyte-${DIGIBYTE_VERSION}-x86_64-linux-gnu.tar.gz" > /dev/null \
    && tar -xzf "digibyte-${DIGIBYTE_VERSION}-x86_64-linux-gnu.tar.gz" \
    && cp "digibyte-${DIGIBYTE_VERSION}/bin/"* /usr/local/bin/ \
    && rm -rf /tmp/*

# Create entrypoint script
# Config is mounted from host by docker-compose
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
# Process config template (replace env vars) — skip if user-provided config exists\n\
if [ -f /home/digibyte/.digibyte/digibyte.conf ] && [ -s /home/digibyte/.digibyte/digibyte.conf ]; then\n\
    echo "Using existing digibyte.conf (skipping template generation)"\n\
elif [ -f /config/digibyte.conf.template ]; then\n\
    envsubst < /config/digibyte.conf.template > /home/digibyte/.digibyte/digibyte.conf\n\
    chmod 600 /home/digibyte/.digibyte/digibyte.conf\n\
fi\n\
\n\
# Ensure proper ownership of data directory\n\
chown -R digibyte:digibyte /home/digibyte/.digibyte\n\
\n\
# Start DigiByte daemon\n\
exec gosu digibyte digibyted -printtoconsole "$@"\n\
' > /entrypoint.sh && chmod +x /entrypoint.sh

# Expose ports
# P2P
EXPOSE 12024
# RPC
EXPOSE 14022
# ZMQ
EXPOSE 28532

# Data volume
VOLUME ["/home/digibyte/.digibyte"]

USER root
ENTRYPOINT ["/entrypoint.sh"]
