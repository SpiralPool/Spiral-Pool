# ═══════════════════════════════════════════════════════════════════════════════
# BITCOIN KNOTS - SPIRAL POOL CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Optimized for fast initial blockchain sync and reliable mining operations

# ═══════════════════════════════════════════════════════════════════════════════
# NETWORK SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════
chain=main
listen=1
port=8333

# Maximum peer connections (higher = faster sync, more bandwidth)
maxconnections=125

# Increase upload target for better network health
maxuploadtarget=0

# ═══════════════════════════════════════════════════════════════════════════════
# RPC CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
server=1
rpcuser=${RPC_USER}
rpcpassword=${RPC_PASSWORD}
rpcallowip=127.0.0.1
rpcallowip=172.17.0.0/16
rpcallowip=10.0.0.0/8
rpcallowip=192.168.0.0/16
rpcbind=0.0.0.0
rpcport=8332

# RPC work queue for mining (increase for high hashrate)
rpcworkqueue=128
rpcthreads=8

# ═══════════════════════════════════════════════════════════════════════════════
# ZMQ BLOCK NOTIFICATIONS (for instant job updates)
# ═══════════════════════════════════════════════════════════════════════════════
zmqpubhashblock=tcp://0.0.0.0:28332
zmqpubrawtx=tcp://0.0.0.0:28332
zmqpubrawblock=tcp://0.0.0.0:28332

# High water mark for ZMQ (prevents message drops under load)
zmqpubhashblockhwm=1000

# ═══════════════════════════════════════════════════════════════════════════════
# PERFORMANCE TUNING - OPTIMIZED FOR FAST SYNC
# ═══════════════════════════════════════════════════════════════════════════════
# Database cache size in MB (higher = faster sync, more RAM)
# Recommended: 8192 for initial sync, 2048 for steady state
# Requires ~8GB RAM for initial sync
dbcache=8192

# Signature cache size (higher = faster validation)
maxsigcachesize=250

# Script verification threads (0 = auto-detect CPU cores)
par=0

# Block download window (higher = more parallel downloads)
maxorphantx=100

# Disable mempool during initial sync for speed
# Comment this out after sync completes!
# blocksonly=1

# ═══════════════════════════════════════════════════════════════════════════════
# WALLET (required for solo mining)
# ═══════════════════════════════════════════════════════════════════════════════
disablewallet=0

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════════
printtoconsole=1
# Reduce log verbosity during sync
debug=0
logtimestamps=1
shrinkdebugfile=1
debuglogfile=debug.log
maxdebugfilesize=50

# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE (Full node - no pruning for mining)
# ═══════════════════════════════════════════════════════════════════════════════
prune=0
txindex=1

# ═══════════════════════════════════════════════════════════════════════════════
# DNS SEEDS AND BOOTSTRAP NODES
# ═══════════════════════════════════════════════════════════════════════════════
# Multiple seeds for faster peer discovery (verified against Bitcoin Core chainparams.cpp)
dnsseed=1
addnode=seed.bitcoin.sipa.be
addnode=dnsseed.bluematt.me
addnode=seed.bitcoin.jonasschnelli.ch
addnode=seed.btc.petertodd.net
addnode=seed.bitcoin.sprovoost.nl
addnode=dnsseed.emzy.de
addnode=seed.bitcoin.wiz.biz
addnode=seed.mainnet.achownodes.xyz

# ═══════════════════════════════════════════════════════════════════════════════
# MINING SPECIFIC
# ═══════════════════════════════════════════════════════════════════════════════
# Block size limit for mining
blockmaxweight=4000000

# Minimum relay fee (default is fine for mining)
minrelaytxfee=0.00001
